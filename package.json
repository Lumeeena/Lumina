{
  "name": "lumina",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source event indexer and GraphQL data layer for the Stellar network",
  "workspaces": [
    "graphql-server",
    "indexer"
  ],
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:graphql && npm run build:indexer",
    "build:frontend": "cd frontend && npm run build",
    "build:graphql": "cd graphql-server && npm run build",
    "build:indexer": "cd indexer && npm run build",
    "build:contracts": "cd contracts && cargo build --target wasm32-unknown-unknown --release"
  },
  "engines": {
    "node": ">=18"
  }
}
